# ── Azure SQL Database ──────────────────────────────────────
DB_SERVER=your-server.database.windows.net
DB_NAME=QuizDB
DB_USER=quizadmin
DB_PASSWORD=YourStrongPassword123!
DB_PORT=1433

# ── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ── Security ─────────────────────────────────────────────────
ADMIN_TOKEN=change-this-admin-token-in-production
ALLOWED_ORIGINS=https://your-app.azurewebsites.net

# ── Notifications ────────────────────────────────────────────
# Slack / Teams / Discord / custom webhook URL
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
